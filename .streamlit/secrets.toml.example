# Streamlit Cloud secrets şablonu
# Bu dosyayı secrets.toml olarak kopyalayıp gerçek key'leri girin.
# secrets.toml git'e eklenmez (.gitignore'da), bu şablon eklenir.

# Anthropic Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY = "buraya-anthropic-api-anahtarinizi-yazin"

# Hangi Claude modeli (varsayılan: claude-sonnet-4-6)
CLAUDE_MODEL = "claude-sonnet-4-6"

# Google Gemini API — yedek / geliştirme için (https://aistudio.google.com)
GEMINI_API_KEY = "buraya-gemini-api-anahtarinizi-yazin"
GEMINI_MODEL = "gemini-2.5-flash"
