# Anthropic Claude API anahtarı (https://console.anthropic.com — ücretli)
ANTHROPIC_API_KEY=buraya-anthropic-api-anahtarinizi-yazin

# Hangi modeli kullanacaksın (varsayılan: claude-sonnet-4-6)
# - claude-haiku-4-5-20251001 : En hızlı, en ucuz
# - claude-sonnet-4-6         : Hız + kalite dengesi (önerilen)
# - claude-opus-4-8           : En güçlü, en pahalı
CLAUDE_MODEL=claude-sonnet-4-6

# Sitenin canlı adresi (robots.txt / sitemap.xml için kullanılır)
SITE_URL=https://cvdoktoru.com

# Fake-door analytics özet endpoint'ini korumak için rastgele, uzun bir anahtar üretin
# (örn. `openssl rand -hex 24`). Boş bırakılırsa /api/analytics/summary her zaman 403 döner.
ANALYTICS_ADMIN_KEY=

# IP hash'lemede kullanılan tuz — rastgele bir değerle değiştirin
ANALYTICS_SALT=degistir-bu-degeri
